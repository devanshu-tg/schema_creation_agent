# Copy this to .env and fill in your TigerGraph connection details.
# tg-schema deploy reads these via tigergraph-mcp.

# ---- Default profile ----
TG_HOST=http://localhost
TG_GRAPHNAME=fraud_graph
TG_USERNAME=tigergraph
TG_PASSWORD=tigergraph
TG_RESTPP_PORT=9000
TG_GS_PORT=14240

# Or use an API token instead of username/password:
# TG_API_TOKEN=your_api_token_here

# Set to true if connecting to TigerGraph Savanna (TGCloud):
# TG_TGCLOUD=false

# ---- Optional: named profiles ----
# Each profile prefixes the TG_* variables with <NAME>_.
# Variables not set on a named profile fall back to the default profile.

# STAGING_TG_HOST=https://staging.example.com
# STAGING_TG_API_TOKEN=staging_token
# STAGING_TG_TGCLOUD=true

# PROD_TG_HOST=https://prod.example.com
# PROD_TG_USERNAME=admin
# PROD_TG_PASSWORD=prod_secret
# PROD_TG_GRAPHNAME=ProdGraph
# PROD_TG_TGCLOUD=true

# Pick which profile to use by default:
# TG_PROFILE=staging
